NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173,https://your-frontend.vercel.app

MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/chainescrow?retryWrites=true&w=majority
MONGO_DB_NAME=chainescrow
MONGO_MAX_POOL_SIZE=20
MONGO_MIN_POOL_SIZE=2

JWT_SECRET=replace-with-a-very-long-random-secret-at-least-32-characters
JWT_EXPIRES_IN=7d

BODY_LIMIT=2mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/<INFURA_PROJECT_ID>
PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY
CHAINESCROW_CONTRACT_ADDRESS=0xYOUR_DEPLOYED_CONTRACT

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
CLOUDINARY_FOLDER=escrowlance/proofs

ALLOWED_UPLOAD_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf,text/plain,application/zip,application/x-zip-compressed
MAX_UPLOAD_FILE_SIZE_MB=10

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=super-secret
SMTP_FROM=noreply@example.com
