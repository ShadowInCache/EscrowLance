  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.1"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.9.5",
    "chainescrow": "file:.."
  }
}
